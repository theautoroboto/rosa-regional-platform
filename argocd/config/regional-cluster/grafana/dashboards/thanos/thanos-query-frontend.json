{
  "title": "Thanos Query Frontend",
  "uid": "thanos-query-frontend",
  "description": "Memory, performance, and health metrics for the Thanos Query Frontend. Use this dashboard to diagnose OOMKill events and query performance issues.",
  "tags": ["thanos", "observability", "sre"],
  "timezone": "browser",
  "refresh": "1m",
  "schemaVersion": 38,
  "graphTooltip": 1,
  "time": { "from": "now-3h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "label": "Datasource",
        "query": "prometheus",
        "current": { "text": "Thanos", "value": "Thanos" },
        "hide": 0,
        "refresh": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Overview",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Restart Count",
      "description": "Total container restarts for thanos-query-frontend. Elevated restarts indicate OOMKills or liveness probe failures.",
      "gridPos": { "x": 0, "y": 1, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "max(kube_pod_container_status_restarts_total{namespace=\"thanos\", container=\"thanos-query-frontend\"})",
          "legendFormat": "Restarts"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 1, "color": "yellow" },
              { "value": 5, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Last Termination: OOMKilled",
      "description": "Whether the last termination reason was OOMKilled. A value of 1 means the container was killed by the kernel for exceeding its memory limit.",
      "gridPos": { "x": 6, "y": 1, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "max(kube_pod_container_status_last_terminated_reason{namespace=\"thanos\", container=\"thanos-query-frontend\", reason=\"OOMKilled\"}) or on() vector(0)",
          "legendFormat": "OOMKilled"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "No", "color": "green", "index": 0 },
                "1": { "text": "Yes", "color": "red", "index": 1 }
              }
            }
          ],
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 1, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Memory Working Set",
      "description": "Current memory working set — the metric the OOMKiller uses to decide when to kill the container.",
      "gridPos": { "x": 12, "y": 1, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "max(container_memory_working_set_bytes{namespace=\"thanos\", container=\"thanos-query-frontend\"})",
          "legendFormat": "Working Set"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 2147483648, "color": "yellow" },
              { "value": 2684354560, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Memory Utilization",
      "description": "Memory working set as a percentage of the configured limit. Values above 85% risk an OOMKill.",
      "gridPos": { "x": 18, "y": 1, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "max(container_memory_working_set_bytes{namespace=\"thanos\", container=\"thanos-query-frontend\"}) / max(container_spec_memory_limit_bytes{namespace=\"thanos\", container=\"thanos-query-frontend\"}) * 100",
          "legendFormat": "Utilization %"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 70, "color": "yellow" },
              { "value": 85, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 10,
      "type": "row",
      "title": "Memory",
      "gridPos": { "x": 0, "y": 5, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Memory Working Set vs Limit",
      "description": "Memory working set and RSS over time compared to the configured limit. When working set reaches the limit the container is OOMKilled.",
      "gridPos": { "x": 0, "y": 6, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "max(container_memory_working_set_bytes{namespace=\"thanos\", container=\"thanos-query-frontend\"})",
          "legendFormat": "Working Set"
        },
        {
          "refId": "B",
          "expr": "max(container_memory_rss{namespace=\"thanos\", container=\"thanos-query-frontend\"})",
          "legendFormat": "RSS"
        },
        {
          "refId": "C",
          "expr": "max(container_spec_memory_limit_bytes{namespace=\"thanos\", container=\"thanos-query-frontend\"})",
          "legendFormat": "Limit"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Limit" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } },
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } },
              { "id": "custom.fillOpacity", "value": 0 }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 20,
      "type": "row",
      "title": "HTTP Performance",
      "gridPos": { "x": 0, "y": 14, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Request Rate",
      "description": "HTTP requests per second by handler.",
      "gridPos": { "x": 0, "y": 15, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_requests_total{namespace=\"thanos\", pod=~\"thanos-query-frontend-.*\"}[5m])) by (handler)",
          "legendFormat": "{{handler}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 5 }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "Error Rate (5xx)",
      "description": "HTTP 5xx errors per second. Spikes often indicate downstream query failures or timeouts.",
      "gridPos": { "x": 8, "y": 15, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_requests_total{namespace=\"thanos\", pod=~\"thanos-query-frontend-.*\", code=~\"5..\"}[5m])) by (handler)",
          "legendFormat": "{{handler}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "color": { "mode": "fixed", "fixedColor": "red" }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },
    {
      "id": 23,
      "type": "timeseries",
      "title": "Request Duration (p50 / p90 / p99)",
      "description": "HTTP request duration percentiles. High latency on /api/v1/query_range often correlates with large responses being buffered in memory.",
      "gridPos": { "x": 16, "y": 15, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{namespace=\"thanos\", pod=~\"thanos-query-frontend-.*\"}[5m])) by (le, handler))",
          "legendFormat": "p50 {{handler}}"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.90, sum(rate(http_request_duration_seconds_bucket{namespace=\"thanos\", pod=~\"thanos-query-frontend-.*\"}[5m])) by (le, handler))",
          "legendFormat": "p90 {{handler}}"
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{namespace=\"thanos\", pod=~\"thanos-query-frontend-.*\"}[5m])) by (le, handler))",
          "legendFormat": "p99 {{handler}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2, "fillOpacity": 5 }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    }
  ]
}

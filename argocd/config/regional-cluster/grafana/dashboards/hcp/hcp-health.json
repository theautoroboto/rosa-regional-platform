{
  "title": "HCP Health",
  "uid": "hcp-health",
  "description": "Comprehensive health dashboard for Hosted Control Planes. Select an HCP namespace to view API server and etcd metrics. HCP components run as pods on Management Clusters.",
  "tags": ["kubernetes", "hcp", "etcd", "apiserver", "sre"],
  "timezone": "browser",
  "refresh": "1m",
  "schemaVersion": 38,
  "graphTooltip": 1,
  "time": { "from": "now-3h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "label": "Datasource",
        "query": "prometheus",
        "current": { "text": "Thanos", "value": "Thanos" },
        "hide": 0,
        "refresh": 1
      },
      {
        "name": "namespace",
        "type": "query",
        "label": "HCP Namespace",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(apiserver_request_total{namespace=~\"clusters-.*\"}, namespace)",
        "refresh": 2,
        "multi": false,
        "includeAll": true,
        "allValue": ".*",
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "API Server",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total etcd Object Count",
      "description": "Total objects stored across all etcd keys as reported by the API server (apiserver_storage_objects). A proxy for etcd database size — consistent growth without corresponding cluster activity indicates resource accumulation.",
      "gridPos": { "x": 0, "y": 1, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(apiserver_storage_objects{namespace=~\"$namespace\"})",
          "legendFormat": "Objects"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "blue" },
              { "value": 50000, "color": "yellow" },
              { "value": 100000, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "API Server Request Rate",
      "description": "Total requests/sec to the API server. High request rates directly stress etcd (every write and most reads touch etcd). Proxy for etcd client traffic load.",
      "gridPos": { "x": 6, "y": 1, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(apiserver_request_total{namespace=~\"$namespace\"}[5m]))",
          "legendFormat": "req/s"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "value": null, "color": "blue" }]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "API Server Error Rate (5xx)",
      "description": "Server-side errors as a percentage of all requests. Sustained 5xx errors can indicate etcd timeouts or write failures surfacing through the API server. Alert threshold: >1%.",
      "gridPos": { "x": 12, "y": 1, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * sum(rate(apiserver_request_total{namespace=~\"$namespace\",code=~\"5..\"}[5m])) / sum(rate(apiserver_request_total{namespace=~\"$namespace\"}[5m]))",
          "legendFormat": "5xx %"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 1, "color": "yellow" },
              { "value": 5, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "API Request Latency p99 (non-WATCH)",
      "description": "p99 API request latency excluding WATCH. Elevated latency is an early indicator of etcd read/write slowness. SRE standard: p99 <1s for GET/LIST, <500ms for mutating verbs.",
      "gridPos": { "x": 18, "y": 1, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(apiserver_request_duration_seconds_bucket{namespace=~\"$namespace\",verb!=\"WATCH\"}[5m])))",
          "legendFormat": "p99"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 1, "color": "yellow" },
              { "value": 5, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "etcd Object Count by Resource (Top 15)",
      "description": "Number of objects per resource type stored in etcd. Consistent growth in events, pods, or secrets can indicate accumulation of stale objects and etcd pressure.",
      "gridPos": { "x": 0, "y": 5, "w": 24, "h": 9 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(15, sum by (resource) (apiserver_storage_objects{namespace=~\"$namespace\"}))",
          "legendFormat": "{{ resource }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": ["lastNotNull", "max"]
        }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "API Request Latency by Verb — p50 / p99",
      "description": "Latency percentiles per HTTP verb (WATCH excluded). Elevated GET/LIST latency signals etcd read slowness; elevated PUT/DELETE/POST latency proxies etcd write / WAL fsync slowness.",
      "gridPos": { "x": 0, "y": 14, "w": 24, "h": 9 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.99, sum by (verb, le) (rate(apiserver_request_duration_seconds_bucket{namespace=~\"$namespace\",verb!=\"WATCH\"}[5m])))",
          "legendFormat": "p99 — {{ verb }}"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.50, sum by (verb, le) (rate(apiserver_request_duration_seconds_bucket{namespace=~\"$namespace\",verb!=\"WATCH\"}[5m])))",
          "legendFormat": "p50 — {{ verb }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 1, "color": "red" }
            ]
          },
          "custom": { "thresholdsStyle": { "mode": "dashed" } }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "max"]
        }
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "API Write Request Rate by Verb",
      "description": "Rate of mutating verbs (POST, PUT, PATCH, DELETE). Each mutating API request results in an etcd write.",
      "gridPos": { "x": 0, "y": 23, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (verb) (rate(apiserver_request_total{namespace=~\"$namespace\",verb=~\"POST|PUT|PATCH|DELETE\"}[5m]))",
          "legendFormat": "{{ verb }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "max"]
        }
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Watch Event Rate by Kind",
      "description": "Events dispatched to active watchers per kind. High watch event rates correspond to etcd change notification volume.",
      "gridPos": { "x": 12, "y": 23, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (kind) (rate(apiserver_watch_events_total{namespace=~\"$namespace\"}[5m]))",
          "legendFormat": "{{ kind }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "eps",
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "max"]
        }
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Dropped Requests (API Priority & Fairness)",
      "description": "Requests rejected by API priority and fairness flow control. Sustained rejections indicate the API server (and thus etcd) is saturated.",
      "gridPos": { "x": 0, "y": 31, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (flow_schema, priority_level) (rate(apiserver_flowcontrol_rejected_requests_total{namespace=~\"$namespace\"}[5m]))",
          "legendFormat": "{{ priority_level }} / {{ flow_schema }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 1, "color": "red" }
            ]
          },
          "custom": { "thresholdsStyle": { "mode": "dashed" } }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "max"]
        }
      }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "In-Flight Requests",
      "description": "Currently active requests being processed by the API server. Sustained high values indicate API server — and by extension, etcd — saturation. Broken out by request kind (mutating vs read-only).",
      "gridPos": { "x": 12, "y": 31, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (request_kind) (apiserver_current_inflight_requests{namespace=~\"$namespace\"})",
          "legendFormat": "{{ request_kind }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 200, "color": "yellow" },
              { "value": 400, "color": "red" }
            ]
          },
          "custom": { "thresholdsStyle": { "mode": "dashed" } }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "max"]
        }
      }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Admission Webhook Latency p99",
      "description": "p99 time spent in each admission webhook. Slow webhooks add latency to every mutating request, which chains into etcd write latency.",
      "gridPos": { "x": 0, "y": 39, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.99, sum by (name, le) (rate(apiserver_admission_webhook_admission_duration_seconds_bucket{namespace=~\"$namespace\"}[5m])))",
          "legendFormat": "{{ name }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 0.5, "color": "yellow" },
              { "value": 1, "color": "red" }
            ]
          },
          "custom": { "thresholdsStyle": { "mode": "dashed" } }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "max"]
        }
      }
    },

    {
      "id": 200,
      "type": "row",
      "title": "etcd",
      "gridPos": { "x": 0, "y": 47, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 21,
      "type": "stat",
      "title": "Leader Changes (1h)",
      "description": "Leader elections in the last hour. Frequent changes indicate instability — network issues, disk pressure, or resource contention.",
      "gridPos": { "x": 0, "y": 48, "w": 8, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(etcd_server_leader_changes_seen_total{namespace=~\"$namespace\"}[1h]))",
          "legendFormat": "changes"
        }
      ],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 3, "color": "yellow" },
              { "value": 10, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 22,
      "type": "stat",
      "title": "DB Size",
      "description": "Total etcd database size. Default quota is 2 GiB for HCP. Approaching the quota triggers alarms and blocks writes.",
      "gridPos": { "x": 8, "y": 48, "w": 8, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "max(etcd_mvcc_db_total_size_in_bytes{namespace=~\"$namespace\"})",
          "legendFormat": "DB size"
        }
      ],
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 1073741824, "color": "yellow" },
              { "value": 1825361101, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 23,
      "type": "stat",
      "title": "DB Space Used %",
      "description": "Percentage of etcd DB size relative to the in-use size. A large gap between total size and in-use size means compaction + defragmentation is needed.",
      "gridPos": { "x": 16, "y": 48, "w": 8, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * max(etcd_mvcc_db_total_size_in_use_in_bytes{namespace=~\"$namespace\"}) / max(etcd_mvcc_db_total_size_in_bytes{namespace=~\"$namespace\"})",
          "legendFormat": "used %"
        }
      ],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 50, "color": "yellow" },
              { "value": 80, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "id": 24,
      "type": "timeseries",
      "title": "DB Size Over Time",
      "description": "etcd database total size and in-use size. The gap between total and in-use indicates dead space reclaimable by defragmentation.",
      "gridPos": { "x": 0, "y": 52, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "max by (namespace) (etcd_mvcc_db_total_size_in_bytes{namespace=~\"$namespace\"})",
          "legendFormat": "{{ namespace }} — total"
        },
        {
          "refId": "B",
          "expr": "max by (namespace) (etcd_mvcc_db_total_size_in_use_in_bytes{namespace=~\"$namespace\"})",
          "legendFormat": "{{ namespace }} — in use"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 10 }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "max"]
        }
      }
    },
    {
      "id": 25,
      "type": "timeseries",
      "title": "WAL Fsync Duration (p50 / p99)",
      "description": "Write-ahead log fsync latency. Most critical disk I/O metric for etcd. Values above 10ms cause leader instability and election storms.",
      "gridPos": { "x": 0, "y": 60, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.99, sum by (namespace, le) (rate(etcd_disk_wal_fsync_duration_seconds_bucket{namespace=~\"$namespace\"}[5m])))",
          "legendFormat": "{{ namespace }} — p99"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.50, sum by (namespace, le) (rate(etcd_disk_wal_fsync_duration_seconds_bucket{namespace=~\"$namespace\"}[5m])))",
          "legendFormat": "{{ namespace }} — p50"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 0.01, "color": "yellow" },
              { "value": 0.1, "color": "red" }
            ]
          },
          "custom": { "thresholdsStyle": { "mode": "dashed" } }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "max"]
        }
      }
    },
    {
      "id": 26,
      "type": "timeseries",
      "title": "Backend Commit Duration (p50 / p99)",
      "description": "boltdb commit latency. Sustained values above 25ms degrade write throughput.",
      "gridPos": { "x": 12, "y": 60, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.99, sum by (namespace, le) (rate(etcd_disk_backend_commit_duration_seconds_bucket{namespace=~\"$namespace\"}[5m])))",
          "legendFormat": "{{ namespace }} — p99"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.50, sum by (namespace, le) (rate(etcd_disk_backend_commit_duration_seconds_bucket{namespace=~\"$namespace\"}[5m])))",
          "legendFormat": "{{ namespace }} — p50"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 0.025, "color": "yellow" },
              { "value": 0.1, "color": "red" }
            ]
          },
          "custom": { "thresholdsStyle": { "mode": "dashed" } }
        }
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "max"]
        }
      }
    }
  ]
}

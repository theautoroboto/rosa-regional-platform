{
  "title": "EKS Standards",
  "uid": "eks-standards",
  "description": "Industry-standard EKS health: availability, resource saturation, reliability, and capacity",
  "tags": ["kubernetes", "eks", "sre"],
  "timezone": "browser",
  "refresh": "1m",
  "schemaVersion": 38,
  "graphTooltip": 1,
  "time": { "from": "now-3h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "label": "Datasource",
        "query": "prometheus",
        "current": { "text": "Thanos", "value": "Thanos" },
        "hide": 0,
        "refresh": 1
      },
      {
        "name": "cluster",
        "type": "query",
        "label": "Cluster",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(kube_node_info, cluster)",
        "refresh": 2,
        "multi": false,
        "includeAll": true,
        "allValue": ".*",
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Nodes Ready",
      "description": "Number of nodes in Ready state. Any drop signals a node failure.",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "count(kube_node_status_condition{condition=\"Ready\",status=\"true\",cluster=~\"$cluster\"})",
          "legendFormat": "Ready"
        }
      ],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "red" }, { "value": 1, "color": "green" }] }
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Pods Running",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "count(kube_pod_status_phase{phase=\"Running\",cluster=~\"$cluster\"})",
          "legendFormat": "Running"
        }
      ],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "blue" }] } } }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Pods Pending",
      "description": "Pending pods indicate scheduling pressure or resource exhaustion.",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "count(kube_pod_status_phase{phase=\"Pending\",cluster=~\"$cluster\"}) or vector(0)",
          "legendFormat": "Pending"
        }
      ],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "green" }, { "value": 1, "color": "yellow" }, { "value": 5, "color": "red" }] }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Container Restarts (1h)",
      "description": "Total container restarts in the last hour. High values indicate instability.",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(kube_pod_container_status_restarts_total{cluster=~\"$cluster\"}[1h]))",
          "legendFormat": "Restarts"
        }
      ],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "green" }, { "value": 5, "color": "yellow" }, { "value": 20, "color": "red" }] }
        }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "OOMKills (1h)",
      "description": "Containers killed by OOM in the last hour. Non-zero indicates memory limits are too low.",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(kube_pod_container_status_last_terminated_reason{reason=\"OOMKilled\",cluster=~\"$cluster\"}[1h])) or vector(0)",
          "legendFormat": "OOMKills"
        }
      ],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "green" }, { "value": 1, "color": "red" }] }
        }
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Pods Without Resource Requests",
      "description": "Pods with no CPU or memory requests set. Industry standard: 0. These cause unpredictable scheduling.",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "count(kube_pod_status_phase{phase=\"Running\",cluster=~\"$cluster\"}) - count(kube_pod_container_resource_requests{resource=\"memory\",cluster=~\"$cluster\"})",
          "legendFormat": "No Requests"
        }
      ],
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "green" }, { "value": 1, "color": "yellow" }, { "value": 5, "color": "red" }] }
        }
      }
    },
    {
      "id": 7,
      "type": "gauge",
      "title": "Cluster CPU Utilization",
      "description": "Industry standard alert threshold: >80%",
      "gridPos": { "x": 0, "y": 4, "w": 6, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * (1 - avg(rate(node_cpu_seconds_total{mode=\"idle\",cluster=~\"$cluster\"}[5m])))",
          "legendFormat": "CPU %"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "minVizWidth": 75, "minVizHeight": 75 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "green" }, { "value": 70, "color": "yellow" }, { "value": 80, "color": "red" }] }
        }
      }
    },
    {
      "id": 8,
      "type": "gauge",
      "title": "Cluster Memory Utilization",
      "description": "Industry standard alert threshold: >85%",
      "gridPos": { "x": 6, "y": 4, "w": 6, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * (1 - sum(node_memory_MemAvailable_bytes{cluster=~\"$cluster\"}) / sum(node_memory_MemTotal_bytes{cluster=~\"$cluster\"}))",
          "legendFormat": "Memory %"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "minVizWidth": 75, "minVizHeight": 75 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "green" }, { "value": 75, "color": "yellow" }, { "value": 85, "color": "red" }] }
        }
      }
    },
    {
      "id": 9,
      "type": "gauge",
      "title": "CPU Request Commitment",
      "description": "% of allocatable CPU requested by pods. >100% means overcommitted.",
      "gridPos": { "x": 12, "y": 4, "w": 6, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * sum(kube_pod_container_resource_requests{resource=\"cpu\",cluster=~\"$cluster\"}) / sum(kube_node_status_allocatable{resource=\"cpu\",cluster=~\"$cluster\"})",
          "legendFormat": "CPU Commitment %"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "minVizWidth": 75, "minVizHeight": 75 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 150,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "green" }, { "value": 80, "color": "yellow" }, { "value": 100, "color": "red" }] }
        }
      }
    },
    {
      "id": 10,
      "type": "gauge",
      "title": "Memory Request Commitment",
      "description": "% of allocatable memory requested by pods. >100% means overcommitted.",
      "gridPos": { "x": 18, "y": 4, "w": 6, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * sum(kube_pod_container_resource_requests{resource=\"memory\",cluster=~\"$cluster\"}) / sum(kube_node_status_allocatable{resource=\"memory\",cluster=~\"$cluster\"})",
          "legendFormat": "Memory Commitment %"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "minVizWidth": 75, "minVizHeight": 75 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 150,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "green" }, { "value": 80, "color": "yellow" }, { "value": 100, "color": "red" }] }
        }
      }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "CPU Usage vs Requests vs Limits by Node",
      "description": "Actual usage vs requested vs limit. Gap between usage and limit = headroom.",
      "gridPos": { "x": 0, "y": 10, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (node) (rate(node_cpu_seconds_total{mode!=\"idle\",cluster=~\"$cluster\"}[5m]))",
          "legendFormat": "usage – {{ node }}"
        },
        {
          "refId": "B",
          "expr": "sum by (node) (kube_pod_container_resource_requests{resource=\"cpu\",cluster=~\"$cluster\"})",
          "legendFormat": "requested – {{ node }}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" } } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] } }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Memory Usage vs Requests vs Limits by Node",
      "gridPos": { "x": 12, "y": 10, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (node) (node_memory_MemTotal_bytes{cluster=~\"$cluster\"} - node_memory_MemAvailable_bytes{cluster=~\"$cluster\"})",
          "legendFormat": "usage – {{ node }}"
        },
        {
          "refId": "B",
          "expr": "sum by (node) (kube_pod_container_resource_requests{resource=\"memory\",cluster=~\"$cluster\"})",
          "legendFormat": "requested – {{ node }}"
        },
        {
          "refId": "C",
          "expr": "sum by (node) (kube_pod_container_resource_limits{resource=\"memory\",cluster=~\"$cluster\"})",
          "legendFormat": "limit – {{ node }}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes", "color": { "mode": "palette-classic" } } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] } }
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Container Restart Rate",
      "description": "Sustained restart rate indicates crashlooping. SRE standard: alert on >5 restarts/hour per container.",
      "gridPos": { "x": 0, "y": 18, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(10, sum by (namespace, pod, container) (increase(kube_pod_container_status_restarts_total{cluster=~\"$cluster\"}[1h])))",
          "legendFormat": "{{ namespace }}/{{ pod }}/{{ container }}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" } } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "sum"] } }
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "CPU Throttling Rate by Container",
      "description": "% of CPU time throttled. >25% throttling indicates limits are too low and impacting performance.",
      "gridPos": { "x": 12, "y": 18, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(10, sum by (namespace, pod, container) (rate(container_cpu_cfs_throttled_seconds_total{container!=\"\",cluster=~\"$cluster\"}[5m])) / sum by (namespace, pod, container) (rate(container_cpu_cfs_periods_total{container!=\"\",cluster=~\"$cluster\"}[5m])) * 100)",
          "legendFormat": "{{ namespace }}/{{ pod }}/{{ container }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0,
          "color": { "mode": "palette-classic" },
          "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "green" }, { "value": 25, "color": "red" }] },
          "custom": { "thresholdsStyle": { "mode": "dashed" } }
        }
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] } }
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "Network I/O by Node",
      "description": "Sustained high bandwidth may indicate noisy neighbors or misconfigured workloads.",
      "gridPos": { "x": 0, "y": 26, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (instance) (rate(node_network_receive_bytes_total{device!~\"lo|veth.*|docker.*\",cluster=~\"$cluster\"}[5m]))",
          "legendFormat": "rx – {{ instance }}"
        },
        {
          "refId": "B",
          "expr": "sum by (instance) (rate(node_network_transmit_bytes_total{device!~\"lo|veth.*|docker.*\",cluster=~\"$cluster\"}[5m]))",
          "legendFormat": "tx – {{ instance }}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps", "color": { "mode": "palette-classic" } } },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] } }
    },
    {
      "id": 16,
      "type": "timeseries",
      "title": "PVC Utilization",
      "description": "Industry standard: alert at >80% full. Full PVCs cause pod crashes.",
      "gridPos": { "x": 12, "y": 26, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * kubelet_volume_stats_used_bytes{cluster=~\"$cluster\"} / kubelet_volume_stats_capacity_bytes{cluster=~\"$cluster\"}",
          "legendFormat": "{{ namespace }}/{{ persistentvolumeclaim }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "color": { "mode": "palette-classic" },
          "thresholds": { "mode": "absolute", "steps": [{ "value": null, "color": "green" }, { "value": 80, "color": "red" }] },
          "custom": { "thresholdsStyle": { "mode": "dashed" } }
        }
      },
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] } }
    },
    {
      "id": 17,
      "type": "table",
      "title": "Top Memory-Consuming Pods",
      "description": "Identify memory hogs. Compare against requests to detect under-provisioned containers.",
      "gridPos": { "x": 0, "y": 34, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(15, sum by (namespace, pod) (container_memory_working_set_bytes{container!=\"\",cluster=~\"$cluster\"}))",
          "legendFormat": "{{ namespace }}/{{ pod }}",
          "instant": true
        }
      ],
      "options": { "sortBy": [{ "displayName": "Value", "desc": true }] },
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 18,
      "type": "table",
      "title": "Pods in Non-Running State",
      "description": "Pending, Failed, or Unknown pods requiring attention.",
      "gridPos": { "x": 12, "y": 34, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "refId": "A",
          "expr": "kube_pod_status_phase{phase!=\"Running\",phase!=\"Succeeded\",cluster=~\"$cluster\"} == 1",
          "legendFormat": "{{ namespace }}/{{ pod }} – {{ phase }}",
          "instant": true
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    }
  ]
}

# Example configuration for Cross-Account Test
# Copy this file to terraform.tfvars and fill in your specific values

# ============================================================================
# Required: Target AWS Accounts
# ============================================================================
# List of AWS Account IDs where cross-account access will be tested
target_account_ids = [
  "123456789012",  # Target Account 1
  "987654321098"   # Target Account 2
]

# Name of the IAM role to assume in target accounts
# This role must exist in each target account with proper trust policy
target_role_name = "OrganizationAccountAccessRole"

# ============================================================================
# Optional: Deployment Region
# ============================================================================
# AWS region to deploy the CodeBuild project and EventBridge rule
# region = "us-east-2"

# ============================================================================
# Optional: Schedule Configuration
# ============================================================================
# How often to run the cross-account test
# Default: Every hour (cron format)
#
# Examples:
#   schedule_expression = "rate(1 hour)"         # Every hour (rate format)
#   schedule_expression = "rate(30 minutes)"     # Every 30 minutes
#   schedule_expression = "rate(1 day)"          # Daily
#   schedule_expression = "cron(0 * * * ? *)"    # Every hour (cron format)
#   schedule_expression = "cron(0 */2 * * ? *)"  # Every 2 hours
#   schedule_expression = "cron(0 9 * * ? *)"    # Daily at 9 AM UTC
#
# schedule_expression = "cron(0 * * * ? *)"

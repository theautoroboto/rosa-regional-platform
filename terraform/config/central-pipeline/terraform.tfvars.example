# Example configuration for Cross-Account Test Pipeline
# Copy this file to terraform.tfvars and fill in your specific values

# ============================================================================
# Required: Target AWS Accounts
# ============================================================================
# List of AWS Account IDs that the pipeline will test cross-account access to
# These are the accounts where the IAM role will be assumed
target_account_ids = [
  "123456789012",  # Target Account 1
  "987654321098"   # Target Account 2
]

# Name of the IAM role to assume in target accounts
# This role must exist in each target account with a trust policy allowing
# the central account's CodeBuild role to assume it
target_role_name = "OrganizationAccountAccessRole"

# ============================================================================
# Optional: Schedule Configuration
# ============================================================================
# How often to run the cross-account test
# Default: Every hour
#
# Examples:
#   schedule_expression = "rate(1 hour)"      # Every hour
#   schedule_expression = "rate(30 minutes)"  # Every 30 minutes
#   schedule_expression = "rate(1 day)"       # Daily
#   schedule_expression = "cron(0 */2 * * ? *)"  # Every 2 hours (cron format)
#   schedule_expression = "cron(0 9 * * ? *)"    # Daily at 9 AM UTC
#
# schedule_expression = "rate(1 hour)"
